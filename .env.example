# Database (MySQL)
# Example: mysql://USER:PASSWORD@HOST:3306/DATABASE_NAME
DATABASE_URL="mysql://user:password@localhost:3306/unida_tech"

# Auth (use strong secrets in production)
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Admin user created by: npm run db:seed
# Optional: set before running seed to use your own credentials
# SEED_ADMIN_EMAIL="admin@unidatechs.com"
# SEED_ADMIN_PASSWORD="Admin123!"

# Optional: Email (e.g. Resend, SendGrid)
# EMAIL_SERVER_HOST=
# EMAIL_SERVER_PORT=
# EMAIL_FROM=
